# ============================================================================
# Subscription Management System — Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# Database (PostgreSQL via pgAdmin4)
# Update with your PostgreSQL credentials
DATABASE_URL="postgresql://postgres:password@localhost:5432/subscription_db?schema=public"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"

# App URL
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (STUB — fill when ready)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (DEFERRED — uncomment when ready)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@subsms.local
