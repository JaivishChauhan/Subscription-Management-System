# ============================================================================
# Subscription Management System — Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# Database (PostgreSQL via pgAdmin4)
# Update with your PostgreSQL credentials
DATABASE_URL="postgresql://postgres:password@localhost:5432/subscription_db?schema=public"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"

# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (legacy stub — optional)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="optional-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# SMTP (DEFERRED — uncomment when ready)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@subsms.local
