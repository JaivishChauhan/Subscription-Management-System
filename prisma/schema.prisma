// ============================================================================
// Subscription Management System — Prisma Schema
// Database: SQLite (dev) → PostgreSQL/Neon (production)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 1. USERS — Authentication & Role-Based Access Control
// ============================================================================

/// Platform users with RBAC enforcement.
/// Roles: admin (full control), internal (operational), portal (subscriber).
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          String    @default("portal") // admin | internal | portal
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Business relations
  contact             Contact?
  subscriptions       Subscription[]
  invoices            Invoice[]
  createdPayments     Payment[]      @relation("PaymentCreator")
  assignedSalesOrders Subscription[] @relation("Salesperson")
  activityLogs        ActivityLog[]  @relation("ActorLogs")

  @@index([email])
  @@index([role])
}

// ============================================================================
// Auth.js Models (NextAuth v5 adapter compatibility)
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// 2. CONTACTS — Customer Profiles (linked to Users)
// ============================================================================

/// Auto-created when a User registers. Stores billing & shipping details.
model Contact {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  company   String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  invoices      Invoice[]
}

// ============================================================================
// 3. PRODUCTS — Catalog with Recurring Pricing Support
// ============================================================================

/// Products support recurring pricing and variant-based customization.
model Product {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("service") // service | goods
  salesPrice  Float
  costPrice   Float    @default(0)
  description String?
  notes       String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants          ProductVariant[]
  recurringPrices   RecurringPrice[]
  subscriptionLines SubscriptionLine[]
  invoiceLines      InvoiceLine[]
  discountProducts  DiscountProduct[]
}

// ============================================================================
// 4. PRODUCT VARIANTS — Attribute-based Pricing Customization
// ============================================================================

/// Variants define extra pricing based on attribute-value pairs.
/// Example: Attribute: "Brand", Value: "Odoo", Extra Price: ₹560
model ProductVariant {
  id         String @id @default(cuid())
  productId  String
  attribute  String // e.g., "Brand", "Tier", "Region"
  value      String // e.g., "Odoo", "Premium", "US"
  extraPrice Float  @default(0)

  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptionLines SubscriptionLine[]
  invoiceLines      InvoiceLine[]

  @@index([productId])
}

// ============================================================================
// 5. RECURRING PLANS — Billing Configuration
// ============================================================================

/// Plans define how subscriptions are billed: period, options, and lifecycle.
model RecurringPlan {
  id            String    @id @default(cuid())
  name          String
  billingPeriod String // daily | weekly | monthly | yearly
  price         Float
  minQuantity   Int       @default(1)
  startDate     DateTime?
  endDate       DateTime?
  autoClose     Boolean   @default(false)
  closable      Boolean   @default(true)
  pausable      Boolean   @default(false)
  renewable     Boolean   @default(true)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recurringPrices    RecurringPrice[]
  subscriptions      Subscription[]
  quotationTemplates QuotationTemplate[]
}

/// Maps a product to a recurring plan with a specific price override.
model RecurringPrice {
  id              String @id @default(cuid())
  productId       String
  recurringPlanId String
  price           Float

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  recurringPlan RecurringPlan @relation(fields: [recurringPlanId], references: [id], onDelete: Cascade)

  @@unique([productId, recurringPlanId])
}

// ============================================================================
// 6. ATTRIBUTES — Standalone Attribute Registry
// ============================================================================

/// Global attribute definitions reusable across products.
model Attribute {
  id        String           @id @default(cuid())
  name      String           @unique // e.g., "Brand", "Region", "Tier"
  createdAt DateTime         @default(now())
  values    AttributeValue[]
}

model AttributeValue {
  id          String @id @default(cuid())
  attributeId String
  value       String
  extraPrice  Float  @default(0)

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, value])
}

// ============================================================================
// 7. QUOTATION TEMPLATES — Predefined Subscription Setups
// ============================================================================

/// Templates accelerate subscription creation by pre-filling fields.
model QuotationTemplate {
  id              String   @id @default(cuid())
  name            String
  validityDays    Int      @default(30)
  recurringPlanId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recurringPlan RecurringPlan?          @relation(fields: [recurringPlanId], references: [id])
  lines         QuotationTemplateLine[]
}

model QuotationTemplateLine {
  id                  String  @id @default(cuid())
  quotationTemplateId String
  productName         String
  description         String?
  quantity            Int     @default(1)
  unitPrice           Float

  quotationTemplate QuotationTemplate @relation(fields: [quotationTemplateId], references: [id], onDelete: Cascade)
}

// ============================================================================
// 8. SUBSCRIPTIONS — Core Lifecycle Management
// ============================================================================

/// Subscriptions follow a strict lifecycle:
/// Draft → Quotation → Confirmed → Active → Closed
/// Status transitions are enforced — no skipping stages.
model Subscription {
  id                 String    @id @default(cuid())
  subscriptionNumber String    @unique
  status             String    @default("draft") // draft | quotation | confirmed | active | closed
  contactId          String
  userId             String
  salespersonId      String?
  recurringPlanId    String
  paymentTermsId     String?
  startDate          DateTime?
  expirationDate     DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  contact       Contact       @relation(fields: [contactId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  salesperson   User?         @relation("Salesperson", fields: [salespersonId], references: [id])
  recurringPlan RecurringPlan @relation(fields: [recurringPlanId], references: [id])
  paymentTerms  PaymentTerms? @relation(fields: [paymentTermsId], references: [id])

  lines    SubscriptionLine[]
  invoices Invoice[]

  @@index([status])
  @@index([contactId])
  @@index([userId])
}

model SubscriptionLine {
  id             String  @id @default(cuid())
  subscriptionId String
  productId      String
  variantId      String?
  quantity       Int     @default(1)
  unitPrice      Float
  taxAmount      Float   @default(0)
  subtotal       Float

  subscription Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
}

// ============================================================================
// 9. INVOICES — Auto-generated from Subscriptions
// ============================================================================

/// Invoice lifecycle: Draft → Confirmed → Paid | Cancelled
model Invoice {
  id             String    @id @default(cuid())
  invoiceNumber  String    @unique
  status         String    @default("draft") // draft | confirmed | paid | cancelled
  subscriptionId String
  contactId      String
  userId         String
  subtotal       Float     @default(0)
  taxTotal       Float     @default(0)
  discountTotal  Float     @default(0)
  total          Float     @default(0)
  amountDue      Float     @default(0)
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription Subscription  @relation(fields: [subscriptionId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  lines        InvoiceLine[]
  payments     Payment[]

  @@index([status])
  @@index([contactId])
  @@index([subscriptionId])
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  productId String
  variantId String?
  name      String
  quantity  Int     @default(1)
  unitPrice Float
  taxAmount Float   @default(0)
  subtotal  Float

  invoice Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

// ============================================================================
// 10. PAYMENTS — Invoice Settlement Records
// ============================================================================

/// Only Admins can create payment records.
model Payment {
  id                    String   @id @default(cuid())
  invoiceId             String
  createdById           String
  paymentMethod         String // credit_card | paypal | bank_transfer | cash | stripe | razorpay
  amount                Float
  paymentDate           DateTime @default(now())
  stripePaymentIntentId String?
  gatewayOrderId        String?
  gatewayPaymentId      String?  @unique
  gatewaySignature      String?
  notes                 String?
  createdAt             DateTime @default(now())

  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  createdBy User    @relation("PaymentCreator", fields: [createdById], references: [id])

  @@index([invoiceId])
}

// ============================================================================
// 11. DISCOUNTS — Promotional Pricing Rules
// ============================================================================

/// Admin-only. Supports fixed and percentage discounts with eligibility rules.
model Discount {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String // fixed | percentage
  value       Float // discount amount or percentage
  minPurchase Float?
  minQuantity Int?
  startDate   DateTime
  endDate     DateTime
  usageLimit  Int?
  usageCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicableProducts DiscountProduct[]

  @@index([code])
}

/// Many-to-many: Discounts ↔ Products
model DiscountProduct {
  id         String @id @default(cuid())
  discountId String
  productId  String

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([discountId, productId])
}

// ============================================================================
// 12. TAXES — Auto-calculated During Invoicing
// ============================================================================

/// Configurable tax rules applied during invoice generation.
model Tax {
  id          String   @id @default(cuid())
  name        String // e.g., "GST 18%", "VAT 20%"
  type        String   @default("percentage") // percentage | fixed
  rate        Float // 18.0 for 18%, or fixed amount
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ============================================================================
// 13. PAYMENT TERMS — Due Date & Early Payment Rules
// ============================================================================

/// Configurable terms for invoice payment schedules.
model PaymentTerms {
  id          String   @id @default(cuid())
  name        String // e.g., "Net 30", "Due on Receipt"
  dueDays     Int      @default(30)
  description String?
  createdAt   DateTime @default(now())

  subscriptions Subscription[]
}

// ============================================================================
// 14. SERVICES — App/Service Catalog (Admin-managed)
// ============================================================================

/// An app or service users can subscribe to (e.g., Netflix, Spotify).
/// @security Admin-only create/update. Public read for marketplace.
model Service {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  category     String // streaming | productivity | ai | music | gaming | creative | cloud | communication | security | fitness
  logoUrl      String? // external CDN URL or /icons/<slug>.svg
  iconKey      String? // Tabler icon name fallback e.g. "IconBrandNetflix"
  color        String   @default("#6366f1") // brand hex color
  monthlyPrice Float
  yearlyPrice  Float?
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bundleServices BundleService[]
  cartItems      CartItem[]

  @@index([category])
  @@index([isActive, isFeatured])
}

// ============================================================================
// 15. BUNDLES — Predefined/Suggested Service Collections with Discounts
// ============================================================================

/// Admin-defined bundles — a named collection of services with a discount.
/// type: predefined (admin curated) | suggested (system-recommended) | custom (user-created)
model Bundle {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  type          String   @default("predefined") // predefined | suggested | custom
  discountType  String   @default("percentage") // percentage | fixed
  discountValue Float    @default(0)
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  createdById   String? // null = admin/system created
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  services  BundleService[]
  cartItems CartItem[]

  @@index([type, isActive])
  @@index([isFeatured])
}

// ============================================================================
// 16. BUNDLE SERVICES — Join table Bundle ↔ Service
// ============================================================================

/// Maps services to bundles. Ordered for consistent display.
model BundleService {
  id        String @id @default(cuid())
  bundleId  String
  serviceId String
  order     Int    @default(0)

  bundle  Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([bundleId, serviceId])
  @@index([bundleId])
}

// ============================================================================
// 17. CART ITEMS — Temporary pre-checkout user selections
// ============================================================================

/// Holds services or bundles in a user's cart before checkout.
/// Only one of serviceId or bundleId is set per row.
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  serviceId String?
  bundleId  String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bundle  Bundle?  @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// 18. ACTIVITY LOGS — System Audit Trail
// ============================================================================

/// Generic event tracking for dashboard and audit features.
model ActivityLog {
  id          String   @id @default(cuid())
  type        String   // e.g., "USER_CREATED", "SUBSCRIPTION_CANCELLED"
  entityType  String   // e.g., "User", "Subscription", "Invoice"
  entityId    String
  actorId     String?  // The user who performed the action
  details     String?  // stringified JSON payload with diffs/metadata
  createdAt   DateTime @default(now())

  actor User? @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
}
